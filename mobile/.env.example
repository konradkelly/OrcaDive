# Copy to .env — see README Quickstart

API_URL=http://127.0.0.1:3000
GITHUB_CLIENT_ID=

# Optional: exact OAuth redirect (must match GitHub OAuth app callback URL).
# Leave blank to use Expo’s default (check Metro for “[GitHub OAuth] Add this exact URL…”).
# GITHUB_REDIRECT_URI=exp://10.0.0.12:8081/--/auth
